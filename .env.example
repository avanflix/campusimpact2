# MongoDB connection string.
# Local example:  mongodb://localhost:27017/cinequest
# Atlas example:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cinequest
MONGODB_URI=mongodb://localhost:27017/cinequest

# Secret used to sign session JWTs. Use a long random string in production.
JWT_SECRET=replace-this-with-a-long-random-secret-in-production
